# Copy to .env and fill every blank secret before starting Docker Compose.
POSTGRES_DB=library
POSTGRES_USER=library_app
POSTGRES_PASSWORD=

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Generate with: openssl rand -base64 48
JWT_SECRET=

# Optional host ports and schema behavior
APP_PORT=8080
POSTGRES_PORT=5432
JPA_DDL_AUTO=update
